          n262 = And [arg0, v260] -> [v261]
          n263 = Const(0x0) [] -> [v262]
          n264 = CmpNe [v261, v262] -> [v263]
          n266 = gamma [
            pred: v263
            in0: %cs:arg
            in1: %os:arg

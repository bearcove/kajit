    n254 = CmpNe [v253, v254] -> [v255]
    n256 = gamma [
      pred: v255
      in0: %cs:n252
      in1: %os:n252
    ] {
      branch 0:
        region {
          args: [%cs, %os]
          results: [%cs:arg, %os:arg]
        }
      branch 1:
        region {
          args: [%cs, %os]
          n255 = ErrorExit(InvalidVarint) [%cs:arg] -> []
          results: [%cs:arg, %os:arg]
        }
    } -> [%cs, %os]
    n263 = gamma [
      pred: v251
      in0: v252
      in1: %cs:n256
      in2: %os:n256
    ] {
      branch 0:
        region {
          args: [arg0, %cs, %os]
          n257 = Const(0x7e) [] -> [v256]
          n258 = And [arg0, v256] -> [v257]
          n259 = Const(0x0) [] -> [v258]
          n260 = CmpNe [v257, v258] -> [v259]
          n262 = gamma [
            pred: v259
            in0: %cs:arg
            in1: %os:arg
          ] {
            branch 0:
              region {
                args: [%cs, %os]
                results: [%cs:arg, %os:arg]
              }
            branch 1:
              region {
                args: [%cs, %os]
                n261 = ErrorExit(InvalidVarint) [%cs:arg] -> []
                results: [%cs:arg, %os:arg]
              }
          } -> [%cs, %os]
          results: [%cs:n262, %os:n262]
        }
      branch 1:
        region {
          args: [arg0, %cs, %os]
          results: [%cs:arg, %os:arg]
        }
    } -> [%cs, %os]
    n264 = ZigzagDecode(wide=true) [v250] -> [v260]
    n265 = WriteToField(offset=8, W8) [v260, %os:n263] -> [%os]
    results: [%cs:n263, %os:n265]
  }
}

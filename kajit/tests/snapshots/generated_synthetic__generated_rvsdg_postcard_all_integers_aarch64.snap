    } -> [%cs, %os]
    n259 = Const(0x0) [] -> [v258]
    n260 = CmpNe [v253, v258] -> [v259]
    n267 = gamma [
      pred: v259
      in0: v254
      in1: %cs:n258
      in2: %os:n258
    ] {

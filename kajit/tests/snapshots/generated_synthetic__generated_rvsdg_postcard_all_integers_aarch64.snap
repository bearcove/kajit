          results: [%cs:n266, %os:n266]
        }
      branch 1:
        region {
          args: [arg0, %cs, %os]
          results: [%cs:arg, %os:arg]
        }
    } -> [%cs, %os]
    n268 = ZigzagDecode(wide=true) [v252] -> [v264]
    n269 = WriteToField(offset=8, W8) [v264, %os:n267] -> [%os]
    results: [%cs:n267, %os:n269]
  }
}

    } -> [v252, v253, v254, v255, %cs, %os]
    n255 = Const(0x0) [] -> [v256]
    n256 = CmpNe [v255, v256] -> [v257]
    n258 = gamma [
      pred: v257
      in0: %cs:n254
      in1: %os:n254
    ] {
      branch 0:
